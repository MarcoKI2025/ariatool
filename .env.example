# Supabase Configuration (Optional - only needed for authentication)
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key_here

# Instructions:
# 1. ARIA works fully offline without these credentials
# 2. Supabase is only used for optional multi-device sync
# 3. Copy this file as .env and fill in your values
